        "class LSTM(nn.Module):\n",
        "  def __init__(self, num_classes, num_layers=2, input_size=1):\n",
        "    super(LSTM, self).__init__()\n",
        "    self.num_classes = num_classes\n",
        "    self.num_layers = num_layers\n",
        "    self.input_size = input_size\n",
        "\n",
        "    self.lstm = nn.LSTM(input_size, hidden_size=128, num_layers=num_layers, batch_first=True)\n",
        "    self.fc_1 = nn.Linear(128, 64)\n",
        "    self.fc = nn.Linear(64, num_classes)\n",
        "\n",
        "  def forward(self, x):\n",
        "    x = x.unsqueeze(-1)\n",
        "    batch_size = x.size(0)\n",
        "    h_0 = torch.zeros(self.num_layers, batch_size, 128, dtype=x.dtype, device=x.device).requires_grad_()\n",
        "    c_0 = torch.zeros(self.num_layers, batch_size, 128, dtype=x.dtype, device=x.device).requires_grad_()\n",
        "    #print(x.shape)\n",
        "    x, (_, _) = self.lstm(x, (h_0, c_0))\n",
        "    x = self.fc_1(x[:, -1, :])\n",
        "    x = self.fc(x)\n",
        "\n",
        "    return x"
      ],
      "metadata": {
        "id": "USpy7xYyJTq1"
